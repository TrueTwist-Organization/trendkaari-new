# Local development — copy to .env and adjust.
# This copy is intentionally disconnected from the live trendkaari.com / Vercel project.

# API server
PORT=3001
JWT_SECRET=change-this-to-a-long-random-secret

# Admin login (created on first server start)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123

# --- Local persistence (default: server/data/store.json) ---
USE_SQLITE=false
SQLITE_PATH=server/data/trendkaari.db

# --- Optional cloud persistence for a NEW deployment only ---
# Use separate credentials/keys from the live site. Do NOT reuse production tokens.

# Turso (https://turso.tech)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Upstash Redis (https://console.upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GitHub — must point to THIS project's repo, not the live Trendkaari_clothing repo
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# Blob storage — use a new store with its own token when you deploy
BLOB_READ_WRITE_TOKEN=

# Order confirmation email (optional for local checkout testing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=
SITE_NAME=Trendkaari
