{
  "name": "fashion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/free-port.js 3001 && concurrently -n web,api -c blue,magenta \"vite\" \"node server/index.js\"",
    "dev:vite": "vite",
    "server": "node server/index.js",
    "dev:all": "npm run dev",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-cutouts": "NUMBA_DISABLE_JIT=1 python3 scripts/generate-cutouts.py",
    "sync-catalog": "node scripts/sync-catalog-to-store.js",
    "migrate:sqlite": "USE_SQLITE=true node scripts/migrate-store-to-sqlite.js",
    "restore-ads": "node scripts/restore-ad-slots.js",
    "enrich-descriptions": "node scripts/enrich-product-descriptions.js",
    "sync-logo": "node scripts/sync-logo.js",
    "fix-titles": "node scripts/fix-generic-product-titles.js && node scripts/enrich-product-descriptions.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.16.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
